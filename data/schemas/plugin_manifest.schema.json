{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nimdagame.local/schemas/plugin_manifest.schema.json",
  "title": "Plugin Manifest",
  "type": "object",
  "required": ["schema_version", "id", "name", "version", "implementation", "capabilities", "hooks"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "implementation": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "enum": ["gdscript", "native", "external_script"]
        },
        "entry": {
          "type": "string"
        },
        "class_name": {
          "type": "string"
        },
        "runtime": {
          "enum": ["editor_only", "runtime"]
        },
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "append_context_json": {
          "type": "boolean"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "hooks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "priority": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "config": {
      "type": "object"
    }
  }
}
