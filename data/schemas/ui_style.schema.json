{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nimdagame.local/schemas/ui_style.schema.json",
  "title": "UI Style",
  "type": "object",
  "required": ["schema_version", "id", "label", "reference_mode", "style_prompt", "negative_prompt", "output_contract"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "reference_mode": {
      "enum": ["text_style", "image_reference"]
    },
    "style_prompt": {
      "type": "string",
      "minLength": 1
    },
    "negative_prompt": {
      "type": "string"
    },
    "reference_image": {
      "type": "string"
    },
    "output_contract": {
      "type": "object",
      "required": ["format", "transparent_background", "safe_border_px", "naming"],
      "additionalProperties": false,
      "properties": {
        "format": {
          "enum": ["png", "webp"]
        },
        "transparent_background": {
          "type": "boolean"
        },
        "safe_border_px": {
          "type": "integer",
          "minimum": 0
        },
        "naming": {
          "type": "string"
        }
      }
    }
  }
}
