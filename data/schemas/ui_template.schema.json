{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nimdagame.local/schemas/ui_template.schema.json",
  "title": "UI Template",
  "type": "object",
  "required": ["schema_version", "id", "label", "canvas_size", "nodes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "canvas_size": {
      "type": "array",
      "prefixItems": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "integer",
          "minimum": 1
        }
      ],
      "minItems": 2,
      "maxItems": 2
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "rect"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "type": {
            "enum": ["panel", "button", "bar", "icon", "badge", "divider", "image", "text"]
          },
          "slot": {
            "type": "string"
          },
          "component": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "rect": {
            "type": "array",
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              },
              {
                "type": "integer",
                "minimum": 1
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ],
            "minItems": 4,
            "maxItems": 4
          },
          "text": {
            "type": "string"
          },
          "text_align": {
            "enum": ["left", "center", "right"]
          },
          "text_color": {
            "type": "string"
          },
          "font_size": {
            "type": "integer",
            "minimum": 1
          },
          "image": {
            "type": "string"
          },
          "image_tint": {
            "type": "string"
          },
          "image_padding": {
            "type": "number"
          },
          "preserve_aspect": {
            "type": "boolean"
          },
          "progress": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "fill_color": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "padding_left": {
            "type": "number"
          },
          "padding_top": {
            "type": "number"
          },
          "wrap": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
