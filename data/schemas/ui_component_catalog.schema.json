{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nimdagame.local/schemas/ui_component_catalog.schema.json",
  "title": "UI Component Catalog",
  "type": "object",
  "required": ["schema_version", "components"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "kind", "states", "nine_patch", "prompt"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "enum": ["panel", "button", "bar", "icon", "decor"]
          },
          "states": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            },
            "uniqueItems": true
          },
          "nine_patch": {
            "type": "array",
            "prefixItems": [
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 },
              { "type": "integer", "minimum": 0 }
            ],
            "minItems": 4,
            "maxItems": 4
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
