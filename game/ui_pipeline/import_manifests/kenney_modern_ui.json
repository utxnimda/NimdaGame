  "asset_libraries": [
    {
      "id": "ui_pack_png",
      "label": "UI Pack PNG",
      "asset_type": "image",
      "source_root": "ui_pack/PNG",
      "output_dir": "ui_pack/png",
      "patterns": ["**/*.png"]
    },
    {
      "id": "ui_pack_sounds",
      "label": "UI Pack Sounds",
      "asset_type": "audio",
      "source_root": "ui_pack/Sounds",
      "output_dir": "ui_pack/sounds",
      "patterns": ["**/*.ogg", "**/*.wav", "**/*.mp3"]
    },
    {
      "id": "ui_pack_fonts",
      "label": "UI Pack Fonts",
      "asset_type": "font",
      "source_root": "ui_pack/Font",
      "output_dir": "ui_pack/fonts",
      "patterns": ["**/*.ttf", "**/*.otf", "**/*.woff", "**/*.woff2"]
    }
  ],
  "legacy_slots": [
