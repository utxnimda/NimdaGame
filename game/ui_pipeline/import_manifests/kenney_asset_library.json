{
  "schema_version": 1,
  "id": "kenney_asset_library",
  "label": "Kenney UI Asset Library",
  "description": "CC0 icon, input prompt, and UI audio libraries imported without registering a skin.",
  "register_style": false,
  "archives": [
    {
      "id": "game_icons",
      "label": "Kenney Game Icons",
      "url": "https://kenney.nl/media/pages/assets/game-icons/1ebf9c14af-1677661579/kenney_game-icons.zip",
      "license": "CC0-1.0"
    },
    {
      "id": "input_prompts",
      "label": "Kenney Input Prompts",
      "url": "https://kenney.nl/media/pages/assets/input-prompts/8de120163f-1777890371/kenney_input-prompts_1.5.zip",
      "license": "CC0-1.0"
    },
    {
      "id": "ui_audio",
      "label": "Kenney UI Audio",
      "url": "https://kenney.nl/media/pages/assets/ui-audio/490d233f68-1677590494/kenney_ui-audio.zip",
      "license": "CC0-1.0"
    }
  ],
  "asset_libraries": [
    {
      "id": "game_icons_png",
      "label": "Game Icons PNG",
      "asset_type": "image",
      "source_root": "game_icons/PNG",
      "output_dir": "game_icons/png",
      "patterns": ["**/*.png"]
    },
    {
      "id": "game_icons_vector",
      "label": "Game Icons Vector",
      "asset_type": "vector",
      "source_root": "game_icons/Vector",
      "output_dir": "game_icons/vector",
      "patterns": ["**/*.svg"]
    },
    {
      "id": "input_prompts_png",
      "label": "Input Prompts PNG",
      "asset_type": "image",
      "source_root": "input_prompts",
      "output_dir": "input_prompts/png",
      "patterns": ["**/*.png"]
    },
    {
      "id": "input_prompts_fonts",
      "label": "Input Prompts Fonts",
      "asset_type": "font",
      "source_root": "input_prompts",
      "output_dir": "input_prompts/fonts",
      "patterns": ["**/*.ttf", "**/*.otf", "**/*.woff", "**/*.woff2"]
    },
    {
      "id": "input_prompts_vector",
      "label": "Input Prompts Vector",
      "asset_type": "vector",
      "source_root": "input_prompts",
      "output_dir": "input_prompts/vector",
      "patterns": ["**/*.svg"]
    },
    {
      "id": "ui_audio",
      "label": "UI Audio",
      "asset_type": "audio",
      "source_root": "ui_audio",
      "output_dir": "ui_audio",
      "patterns": ["**/*.ogg", "**/*.wav", "**/*.mp3"]
    }
  ]
}
